#!/bin/bash
#
# Creates a release tag with proper versioning.
#
# Usage: scripts/make-tag <version>
# Example: scripts/make-tag 0.1.1
#

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info() {
    echo -e "${GREEN}-${NC} $1"
}

warn() {
    echo -e "${YELLOW}!${NC} $1"
}

error() {
    echo -e "${RED}ERROR:${NC} $1" >&2
    exit 1
}

if [ -z "$1" ]; then
    echo "Usage: scripts/make-tag <version>"
    echo "Example: scripts/make-tag 0.1.1"
    exit 1
fi

VERSION="$1"
TAG="v${VERSION}"

# Validate version format (semver)
if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    error "Version must be in semver format (e.g., 0.1.1)"
fi

# Check we're on main branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "main" ]; then
    error "Must be on main branch (currently on '$BRANCH')"
fi

# Check for uncommitted changes
if ! git diff --quiet HEAD; then
    error "Working directory has uncommitted changes"
fi

# Check tag doesn't already exist
if git rev-parse "$TAG" >/dev/null 2>&1; then
    error "Tag $TAG already exists"
fi

# Check CHANGELOG has unreleased content
if ! grep -q "^## \[Unreleased\]" CHANGELOG.md; then
    error "CHANGELOG.md missing [Unreleased] section"
fi

# Extract content between [Unreleased] and next ## section
UNRELEASED_CONTENT=$(sed -n '/^## \[Unreleased\]/,/^## \[/p' CHANGELOG.md | sed '1d;$d')
if [ -z "$(echo "$UNRELEASED_CONTENT" | grep -v '^$' | grep -v '^###')" ]; then
    error "No content in [Unreleased] section of CHANGELOG.md"
fi

echo "Creating release $TAG"
echo ""

# Step 1: Run full build pipeline
info "Running make all (lint, vet, test, build)..."
if ! make all; then
    error "make all failed. Fix issues before releasing."
fi
info "Build pipeline passed"

# Step 2: Update Helm chart versions
CHART="deploy/helm/creel/Chart.yaml"
if [ -f "$CHART" ]; then
    info "Updating Helm chart versions to $VERSION..."
    sed -i.bak "s/^version: .*/version: $VERSION/" "$CHART"
    sed -i.bak "s/^appVersion: .*/appVersion: \"$VERSION\"/" "$CHART"
    rm -f "${CHART}.bak"
fi

# Step 3: Update CHANGELOG.md
info "Updating CHANGELOG.md..."

TODAY=$(date +%Y-%m-%d)

{
    # Keep header (everything before [Unreleased])
    sed -n '1,/^## \[Unreleased\]/p' CHANGELOG.md | sed '$d'
    echo "## [Unreleased]"
    echo ""
    echo "## [$VERSION] - $TODAY"
    # Get content from old Unreleased section (skip first and last lines)
    sed -n '/^## \[Unreleased\]/,/^## \[/p' CHANGELOG.md | sed '1d;$d'
    # Get everything from the next release section onward
    sed -n '/^## \[Unreleased\]/,$p' CHANGELOG.md | sed -n '/^## \[[0-9]/,$p'
} > CHANGELOG.md.new

mv CHANGELOG.md.new CHANGELOG.md

# Step 4: Commit changes
info "Committing version changes..."
git add CHANGELOG.md
[ -f "$CHART" ] && git add "$CHART"
git commit -m "$(cat <<EOF
Release $TAG

- Update Helm chart versions to $VERSION
- Move unreleased changes to $VERSION in CHANGELOG.md
EOF
)"

# Step 5: Create annotated tag
info "Creating tag $TAG..."
git tag -a "$TAG" -m "Release $VERSION"

echo ""
echo -e "${GREEN}Done!${NC} Now run:"
echo ""
echo "  git push origin main $TAG"
echo ""
